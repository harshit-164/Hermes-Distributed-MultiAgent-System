{
  "name": "hermes-v2-os",
  "version": "2.0.0",
  "description": "Distributed Multi-Agent Operating System powered by Supabase, Playwright, and Telegram",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start:builder": "node src/index.js --role=builder",
    "start:research": "node src/index.js --role=research",
    "start:qa": "node src/index.js --role=qa",
    "dev": "node --watch src/index.js --role=builder",
    "test": "vitest run tests/",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-telegram-bot-api": "^0.66.0",
    "playwright": "^1.45.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^9.6.0",
    "supertest": "^7.2.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "distributed",
    "supabase",
    "playwright",
    "telegram"
  ],
  "author": "Hermes Engineering Team",
  "license": "MIT"
}
